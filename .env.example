SHOPIFY_THEME_ID=                    # Optional: specify theme ID, otherwise fetches active theme

# Shopify Cache Configuration (TTL in seconds)
SHOPIFY_CACHE_ENABLED=true
SHOPIFY_CACHE_TTL_PRODUCT=900        # 15 minutes
SHOPIFY_CACHE_TTL_COLLECTION=1800    # 30 minutes
SHOPIFY_CACHE_TTL_CURRENCY=86400     # 24 hours
SHOPIFY_CACHE_TTL_CART=3600          # 1 hour

# Shopify HTTP Client Configuration
SHOPIFY_HTTP_TIMEOUT=30              # seconds
SHOPIFY_HTTP_CONNECT_TIMEOUT=10      # seconds

# Shopify Retry Configuration
SHOPIFY_RETRY_ENABLED=true
SHOPIFY_RETRY_MAX_ATTEMPTS=3
SHOPIFY_RETRY_INITIAL_DELAY_MS=100
SHOPIFY_RETRY_MAX_DELAY_MS=5000
SHOPIFY_RETRY_MULTIPLIER=2.0
SHOPIFY_RETRY_JITTER=true

# Shopify Circuit Breaker Configuration
SHOPIFY_CIRCUIT_BREAKER_ENABLED=true
SHOPIFY_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
SHOPIFY_CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2
SHOPIFY_CIRCUIT_BREAKER_TIMEOUT_SECONDS=60
SHOPIFY_CIRCUIT_BREAKER_WINDOW_SECONDS=120

# Shopify Rate Limiting Configuration
SHOPIFY_RATE_LIMIT_ENABLED=true
SHOPIFY_RATE_LIMIT_MAX_ATTEMPTS=60
SHOPIFY_RATE_LIMIT_DECAY_MINUTES=1

# GraphQL Configuration
GRAPHQL_VERIFY_HASHES=false
GRAPHQL_CACHE_MINUTES=1440

# Currency Configuration
CURRENCY=GBP

FRONTEND_URL=https://scottstonebridge.com/pages/email-readings
BACKEND_URL=https://scottmobileapp.24livehost.com/api

# Admin user ID for generating weekly slots
ADMIN_USER_ID=4